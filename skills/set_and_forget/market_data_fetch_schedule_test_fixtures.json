          "USDJPY"
        ],
        "trigger_time": "2026-03-16T08:00:00Z",
        "execution_timeframe": "240",
        "execution_mode": "paper",
        "max_requests_per_minute": 8,
        "minute_spacing": 1
      },
      "expected": {
