[Unit]
Description=Set & Forget TradingView webhook server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/traderops/setandforget
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/.config/openclaw/gateway.env
ExecStart=/usr/bin/python3 /home/traderops/setandforget/skills/set_and_forget/tradingview_webhook_server.py --host 127.0.0.1 --port 8787
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
