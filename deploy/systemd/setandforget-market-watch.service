[Unit]
Description=Set & Forget guarded market watch batch
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/traderops/setandforget
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/.config/openclaw/gateway.env
ExecStart=/usr/bin/python3 /home/traderops/setandforget/skills/set_and_forget/run_scheduled_market_watch.py --format text
